DB_HOST=localhost
DB_PORT=3306
DB_NAME=ar_presentations
DB_USER=root
DB_PASS=

OPENAI_API_KEY=
PUBLIC_BASE_URL=http://localhost:8000
MAX_FILE_SIZE=20971520
API_RATE_LIMIT_SLEEP=5

# Use "local" for development or "s3" for AWS.
STORAGE_DRIVER=local
AWS_REGION=eu-central-1
AWS_S3_BUCKET=
AWS_S3_PREFIX=ar-presentations

# Optional for local development. Prefer IAM roles in AWS deployments.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional for S3-compatible local development.
AWS_S3_ENDPOINT=
AWS_S3_PATH_STYLE=false
