{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListApplicationPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::ar-presentations-dimitar-sht-360831508656-eu-north-1-an",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "ar-presentations",
            "ar-presentations/*"
          ]
        }
      }
    },
    {
      "Sid": "ManageApplicationObjects",
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::ar-presentations-dimitar-sht-360831508656-eu-north-1-an/ar-presentations/*"
    }
  ]
}
